{
  "version": 1,
  "projects": {
    "aliens-verse-app": {
      "projectType": "application",
      "root": "apps/aliens-verse-app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/apps/aliens-verse-app",
            "browser": "apps/aliens-verse-app/src/main.ts",
            "server": "apps/aliens-verse-app/src/main.server.ts",
            "ssr": {
              "entry": "apps/aliens-verse-app/src/server.ts"
            }
          }
        }
      }
    }
  }
}
